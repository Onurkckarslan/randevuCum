# Environment
ENVIRONMENT=development

# Security
SECRET_KEY=generate-a-random-strong-key-for-production

# Email Service (SendGrid)
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here

# AWS S3
AWS_ACCESS_KEY_ID=AKIA-your-access-key-here
AWS_SECRET_ACCESS_KEY=your-secret-access-key-here
AWS_S3_BUCKET=randevucum-app
AWS_S3_REGION=eu-north-1

# SMS (Optional)
SMS_ENABLED=false
SMS_USER=your-sms-provider-user
SMS_PASS=your-sms-provider-pass
SMS_SENDER=RANDEVUCUM
